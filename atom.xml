  <entry>
    <title>C#打开文件夹或文件</title>
    <link href="http://uerlink.github.io/2022/05/04/%E6%96%87%E6%A1%A3%E5%8C%BA/C%20sharp%E6%89%93%E5%BC%80%E6%96%87%E4%BB%B6%E5%A4%B9%E6%88%96%E6%96%87%E4%BB%B6/"/>
    <id>http://uerlink.github.io/2022/05/04/%E6%96%87%E6%A1%A3%E5%8C%BA/C%20sharp%E6%89%93%E5%BC%80%E6%96%87%E4%BB%B6%E5%A4%B9%E6%88%96%E6%96%87%E4%BB%B6/</id>
    <published>2022-05-04T08:47:16.000Z</published>
    <updated>2022-05-04T10:34:37.033Z</updated>
    
    <content type="html"><![CDATA[<h2 id="选择文件夹"><a href="#选择文件夹" class="headerlink" title="选择文件夹"></a>选择文件夹</h2><pre class="highlight"><span class="line">   <span class="function"><span class="keyword">private</span> <span class="keyword">void</span> <span class="title">btn_select</span>(<span class="params"><span class="built_in">object</span> sender, EventArgs e</span>)</span></span><br><span class="line">   &#123;</span><br><span class="line">       <span class="comment">//新建dialog对象</span></span><br><span class="line">       FolderBrowserDialog dialog = <span class="keyword">new</span> FolderBrowserDialog();</span><br><span class="line">       <span class="comment">//显示文字</span></span><br><span class="line">       dialog.Description = <span class="string">&quot;选择文件夹&quot;</span>;</span><br><span class="line">       <span class="comment">//默认路径</span></span><br><span class="line">       dialog.SelectedPath = <span class="string">@&quot;C:&quot;</span>;</span><br><span class="line">       <span class="comment">//判断文件夹路径是否为空</span></span><br><span class="line">       <span class="keyword">if</span> (dialog.ShowDialog() == System.Windows.Forms.DialogResult.OK)</span><br><span class="line">       &#123;</span><br><span class="line">           <span class="keyword">if</span> (<span class="built_in">string</span>.IsNullOrEmpty(dialog.SelectedPath))</span><br><span class="line">           &#123;</span><br><span class="line">               <span class="comment">//为空提醒</span></span><br><span class="line">               MessageBox.Show(<span class="keyword">this</span>, <span class="string">&quot;文件夹路径不能为空&quot;</span>, <span class="string">&quot;提示&quot;</span>);</span><br><span class="line">               <span class="keyword">return</span>;</span><br><span class="line">           &#125;</span><br><span class="line">           <span class="comment">//命令行提示</span></span><br><span class="line">           Console.WriteLine(<span class="string">&quot;选择了：&quot;</span> + dialog.SelectedPath);</span><br><span class="line"> </span><br><span class="line">       &#125;</span><br><span class="line">       <span class="comment">//保存路径</span></span><br><span class="line"><span class="built_in">string</span> FilesPath = dialog.SelectedPath;</span><br><span class="line">   &#125;</span><br></pre><h2 id="选择文件"><a href="#选择文件" class="headerlink" title="选择文件"></a>选择文件</h2><pre class="highlight"><span class="line">   <span class="function"><span class="keyword">private</span> <span class="built_in">string</span> <span class="title">SelectPath</span>()</span></span><br><span class="line">   &#123;</span><br><span class="line"></span><br><span class="line">       <span class="built_in">string</span> Path = String.Empty;</span><br><span class="line">       OpenFileDialog dialog = <span class="keyword">new</span> OpenFileDialog();</span><br><span class="line">       dialog.Multiselect = <span class="literal">true</span>;<span class="comment">//该值确定是否可以选择多个文件</span></span><br><span class="line">       <span class="comment">//提示文字</span></span><br><span class="line">       dialog.Title = <span class="string">&quot;请选择文件夹&quot;</span>;</span><br><span class="line">       <span class="comment">//设置选择文件类型（）显示的文件 | 过滤的文件</span></span><br><span class="line">       dialog.Filter = <span class="string">&quot;所有文件(*.*)|*.*&quot;</span>;</span><br><span class="line">       <span class="keyword">if</span> (dialog.ShowDialog() == System.Windows.Forms.DialogResult.OK)</span><br><span class="line">       &#123;</span><br><span class="line">           <span class="comment">//变量赋值路径</span></span><br><span class="line">           Path = dialog.FileName;</span><br><span class="line">       &#125;</span><br><span class="line"><span class="comment">//返回文件路径</span></span><br><span class="line">       <span class="keyword">return</span> Path;</span><br><span class="line">   &#125;</span><br></pre><h2 id="打开文件或文件夹"><a href="#打开文件或文件夹" class="headerlink" title="打开文件或文件夹"></a>打开文件或文件夹</h2><pre class="highlight"><span class="line"><span class="comment">//填入文件或文件夹的路径。</span></span><br><span class="line"><span class="comment">//默认</span></span><br><span class="line">System.Diagnostics.Process.Start(<span class="string">&quot;ExpLorer&quot;</span>, <span class="string">&quot;C:\\window&quot;</span>); </span><br><span class="line"></span><br><span class="line"><span class="comment">//选择文件打开方式，并打开</span></span><br><span class="line">    <span class="comment">// 目标文件路径</span></span><br><span class="line"> <span class="built_in">string</span> StartPath = Application.StartupPath + <span class="string">@&quot;\scripts\starthw.bat&quot;</span>;</span><br><span class="line">    <span class="comment">//（方法1） 记事本（特定程序）</span></span><br><span class="line">    <span class="built_in">string</span> NotPath = System.Environment.SystemDirectory + <span class="string">&quot;\\notepad.exe&quot;</span>;</span><br><span class="line">    System.Diagnostics.Process.Start(NotPath, StartPath);    </span><br><span class="line">    <span class="comment">//（方法2） 设置打开方式路径</span></span><br><span class="line">    <span class="built_in">string</span> OpenPath = <span class="string">@&quot;C:\Program Files (x86)\sakura\sakura.exe&quot;</span>;</span><br><span class="line">    System.Diagnostics.Process.Start(OpenPath, StartPath);   </span><br></pre>]]></content>
    
    
      
      
